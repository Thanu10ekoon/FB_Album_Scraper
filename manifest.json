{
  "manifest_version": 3,
  "name": "Facebook Album Downloader",
  "version": "1.0.0",
  "description": "Download entire photo albums from Facebook pages you follow.",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://scontent*.fbcdn.net/*",
    "https://scontent*.xx.fbcdn.net/*",
    "https://*.fbcdn.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
